PORT=5000
NODE_ENV=production

# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_minimum_32_characters

# Railway frontend service URL (no trailing slash)
# Multiple origins: https://a.railway.app,https://b.railway.app
FRONTEND_URL=https://your-frontend.railway.app

# Optional — Groq AI (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key
